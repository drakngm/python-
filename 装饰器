1. 计时装饰器（Timer）

用途：
接口耗时统计
SQL执行时间监控
任务执行时间分析

import time
import logging
from functools import wraps
from typing import Callable, Any


logger = logging.getLogger(__name__)


def timer(func: Callable) -> Callable:
    """
    函数执行耗时统计装饰器

    使用场景:
        - API接口耗时监控
        - 定时任务性能分析
        - 慢函数定位

    示例:
        @timer
        def test():
            pass
    """

    @wraps(func)
    def wrapper(*args, **kwargs) -> Any:

        # 开始时间
        start_time = time.perf_counter()

        try:
            # 执行业务函数
            result = func(*args, **kwargs)

            return result

        finally:
            # 无论成功失败都会记录耗时
            end_time = time.perf_counter()

            cost = end_time - start_time

            logger.info(
                "Function [%s] executed in %.4f seconds",
                func.__name__,
                cost
            )

    return wrapper

2. 重试装饰器（Retry）

用途：

网络请求
第三方接口调用
数据库连接
消息队列消费

import time
import logging
from functools import wraps
from typing import Callable, Type, Tuple, Any


logger = logging.getLogger(__name__)


def retry(
    max_attempts: int = 3,
    delay: float = 1,
    exceptions: Tuple[Type[Exception], ...] = (Exception,)
):
    """
    自动重试装饰器


    参数:
        max_attempts:
            最大尝试次数

        delay:
            每次失败后的等待秒数

        exceptions:
            捕获哪些异常进行重试


    示例:

        @retry(max_attempts=5, delay=2)
        def request_api():
            pass

    """

    def decorator(func: Callable) -> Callable:


        @wraps(func)
        def wrapper(*args, **kwargs) -> Any:


            last_exception = None


            for attempt in range(1, max_attempts + 1):

                try:

                    return func(*args, **kwargs)


                except exceptions as exc:

                    last_exception = exc


                    logger.warning(
                        "Function [%s] failed. "
                        "Attempt %s/%s. Error: %s",
                        func.__name__,
                        attempt,
                        max_attempts,
                        exc
                    )


                    # 最后一次失败，不再等待
                    if attempt < max_attempts:
                        time.sleep(delay)


            # 所有重试失败
            raise last_exception


        return wrapper


    return decorator

3. 权限校验装饰器（Permission）

用途：

管理后台
RBAC权限系统
API接口鉴权

设计：

用户对象：
user.permissions = [
    "user:create",
    "user:delete"
]

from functools import wraps
from typing import Callable, Any
import logging


logger = logging.getLogger(__name__)


class PermissionDenied(Exception):
    """
    权限不足异常
    """
    pass



def permission_required(permission: str):
    """
    权限校验装饰器


    要求:
        被装饰函数第一个参数必须是用户对象


    用户对象示例:

        class User:

            def __init__(self):
                self.permissions = [
                    "user:create"
                ]


    示例:

        @permission_required("user:create")
        def create_user(user):
            pass

    """

    def decorator(func: Callable) -> Callable:


        @wraps(func)
        def wrapper(user, *args, **kwargs) -> Any:


            # 获取用户权限列表
            permissions = getattr(
                user,
                "permissions",
                []
            )


            # 权限检查
            if permission not in permissions:

                logger.warning(
                    "Permission denied. "
                    "User=%s Permission=%s",
                    user,
                    permission
                )


                raise PermissionDenied(
                    f"Missing permission: {permission}"
                )


            # 权限通过
            return func(
                user,
                *args,
                **kwargs
            )


        return wrapper


    return decorator
